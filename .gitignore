# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ---------- dependencies ----------
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# ---------- testing ----------
/coverage

# ---------- next.js ----------
/.next/
/out/

# ---------- production builds ----------
/build

# ---------- OS / editor ----------
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ---------- debug logs ----------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- env (NUNCA commitar) ----------
.env
.env*.local

# ---------- vercel ----------
.vercel

# ---------- typescript ----------
*.tsbuildinfo
next-env.d.ts

# ---------- claude code / council ----------
# Plugin claude-council foi clonado localmente e instalado em ~/.claude/plugins/
# Não commitamos o clone — esta regra fica como guard caso alguém volte a clonar aqui.
/claude-council/
# Cache de respostas do council (gerado em runtime)
/.claude/council-cache/
# Memória/notas privadas do Claude Code (se aparecerem aqui)
/.claude/memory/
